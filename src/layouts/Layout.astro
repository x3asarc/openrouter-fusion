---
interface Props {
  title?: string;
}
const { title = 'OpenRouter Fusion' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      // Apply theme before paint to avoid flash
      (function () {
        try {
          const s = JSON.parse(localStorage.getItem('or_fusion_settings') || '{}');
          if (s.theme === 'light') {
            document.documentElement.classList.remove('dark');
          } else {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="bg-white dark:bg-or-bg text-gray-900 dark:text-white font-sans antialiased h-screen overflow-hidden">
    <slot />
  </body>
</html>
